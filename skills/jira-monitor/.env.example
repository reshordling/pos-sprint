# Jira connection settings
# Copy this file to .env and fill in your values

# Jira base URL
# Cloud:  https://your-company.atlassian.net
# Server: https://jira.your-company.com
JIRA_URL=https://jira.example.com

# Email (Jira Cloud only, leave empty for Server/DC)
JIRA_EMAIL=

# API Token (Cloud) or Personal Access Token (Server/DC)
# Cloud:  https://id.atlassian.com/manage-profile/security/api-tokens
# Server: Profile -> Personal Access Tokens -> Create token
JIRA_API_TOKEN=your-token-here
